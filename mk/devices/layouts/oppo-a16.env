# MT6765 / OPPO A16 (CPH2269) boot image layout defaults.
# These values were captured from the device's stock boot image (via mtkclient).

DEVICE_BASE="0x40078000"
DEVICE_KERNEL_OFFSET="0x00008000"
DEVICE_RAMDISK_OFFSET="0x11a88000"
DEVICE_SECOND_OFFSET="0xbff88000"
DEVICE_TAGS_OFFSET="0x07808000"
DEVICE_DTB_OFFSET="0x07808000"
DEVICE_PAGESIZE="2048"
DEVICE_HEADER_VERSION="2"

DEVICE_CMDLINE="bootopt=64S3,32N2,64N2 buildvariant=user"
DEVICE_BOARD=""
DEVICE_OS_VERSION="11.0.0"
DEVICE_OS_PATCH_LEVEL="2021-10"

# Optional local caches/fallbacks (machine-specific; set in your env, not here):
# - DEVICE_DTB is the cached/built DTB used by default.
# - DEVICE_DTB_SOURCE: the source DTS owning mk-specific chosen props. In the
#   kernel tree it's arch/arm64/boot/dts/mediatek/oppo6765_20379.dts — point
#   $OPPO_A16_DTS at your checkout to enable auto-rebuild from source.
# - DEVICE_STOCK_BOOT: a stock boot.img, only for auto DTB extraction when the
#   cache is missing. Point $OPPO_A16_STOCK_BOOT at your local dump if needed.
DEVICE_DTB="out/dtb/oppo-a16.dtb"
DEVICE_DTB_SOURCE="${OPPO_A16_DTS:-}"
DEVICE_STOCK_BOOT="${OPPO_A16_STOCK_BOOT:-}"

DEVICE_APPEND_SEANDROIDENFORCE="0"
DEVICE_NORMALIZE_V0="0"
