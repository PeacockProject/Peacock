# MT6765 / OPPO A16 (CPH2269) boot image layout defaults.
# These values were captured from /home/tiel/mtkclient/boot_oppo.bin.

DEVICE_BASE="0x40078000"
DEVICE_KERNEL_OFFSET="0x00008000"
DEVICE_RAMDISK_OFFSET="0x11a88000"
DEVICE_SECOND_OFFSET="0xbff88000"
DEVICE_TAGS_OFFSET="0x07808000"
DEVICE_DTB_OFFSET="0x07808000"
DEVICE_PAGESIZE="2048"
DEVICE_HEADER_VERSION="2"

DEVICE_CMDLINE="bootopt=64S3,32N2,64N2 buildvariant=user"
DEVICE_BOARD=""
DEVICE_OS_VERSION="11.0.0"
DEVICE_OS_PATCH_LEVEL="2021-10"

# Optional local caches/fallbacks:
# - DEVICE_DTB can be committed/prebuilt later; until then we cache in out/.
# - DEVICE_STOCK_BOOT is used only for auto DTB extraction when cache is missing.
# - DEVICE_DTB_SOURCE carries the source DTS that owns mk-specific chosen props.
DEVICE_DTB="out/dtb/oppo-a16.dtb"
DEVICE_DTB_SOURCE="/home/tiel/Documents/bro/shen/experiments/android_kernel_oppo_mt6765/arch/arm64/boot/dts/mediatek/oppo6765_20379.dts"
DEVICE_STOCK_BOOT="/home/tiel/mtkclient/boot_oppo.bin"

DEVICE_APPEND_SEANDROIDENFORCE="0"
DEVICE_NORMALIZE_V0="0"
