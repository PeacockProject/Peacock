# ============================================================
# Peacock Project .gitignore
# ============================================================

# ----- Build artifacts & binaries -----
/peacock
struct
*.o
*.a
*.so
*.bin
prp/out/

# ----- Go -----
vendor/

# ----- Large upstream source trees -----
kernel-src/

# ----- Cloned reference repos (each has their own .git) -----
sddm/
sddm-openrc/
dbus-openrc/
elogind/
elogind-openrc/
pmbootstrap/
pbsplash/
tfblib/
prp-references/

# ----- Codex CLI artifacts -----
.codex-tmp/

# ----- Temporary / extracted directories -----
tmp-*/
mnt-rootfs/
lk2nd_port/

# ----- Log files -----
*.log
*.log.old
rc.log
dmesg
keyscan*.log

# ----- Debug / diagnostic config dumps from device -----
# Xorg configs pulled from device
00-serverflags.conf
10-fbdev.conf
10-fbdev.conf.new
xorg.conf
xorg.conf.new
Xorg.0.log
Xorg.0.log.old

# dbus debug copies
dbus.conf
dbus.conf.d.tmp
dbus.conf.pmos
dbus.err
dbus.init.new
dbus.init.pmos
dbus.init.tmp

# elogind debug copies
elogind.conf
elogind.init
elogind.init.tmp

# sddm debug init scripts
sddm.init
sddm.init.new
sddm.init.tmp

# pmos reference configs pulled from device
pmos-conf.d.dbus
pmos-dbus
pmos-elogind
pmos-init.d.dbus
pmos-init.d.elogind
pmos-nsswitch.conf
pmos-system.conf

# stock reference configs pulled from device
stock-conf.d.dbus
stock-conf.d.udev
stock-conf.d.udev-settle
stock-conf.d.udev-trigger
stock-init.d.dbus
stock-init.d.elogind
stock-init.d.udev
stock-init.d.udev-postmount
stock-init.d.udev-settle
stock-init.d.udev-trigger
stock-system.conf

# peacock debug/diagnostic init scripts & configs from device
peacock-boot-marker.init
peacock-conf.d.dbus
peacock-conf.d.elogind
peacock-devdump.init
peacock-devdump2.init
peacock-force-default.init
peacock-init.d.dbus
peacock-init.d.elogind
peacock-nsswitch.conf
peacock-openrc-default
peacock-pam-start-stop-daemon
peacock-rc-default.init
peacock-system.conf
run-tmpfs.init
run-tmpfs.init.new
devfs.init
system.conf.tmp
.tmp_peacock-force-default

# ----- Screenshots and images (root level only) -----
/*.png
/*.ppm
Gemini_Generated_Image_*

# ----- AI session / debug markdown -----
antigravity_log.md
DEBUGGING.md
cursor_peacock_build_error_for_samsung.md
implementation_plan.md
ironing-out-tasklist.md
research_and_requirements.md

# ----- lk2nd debug logs -----
lk2nd-oem-log.txt
lk2nd-oem-log-subpart.txt

# ----- Misc junk -----
\\n/

# ----- OS / editor -----
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/
