#!/bin/sh
set -eu

BB=/sbin/busybox
if [ ! -x "$BB" ]; then
  BB=busybox
fi

BOOT_MNT=/mnt/peacock_boot
ROOT_MNT=/mnt/peacock_root
LOGF=/tmp/prp-subparts.log

log() {
  printf '%s\n' "$*"
}

is_container_dev() {
  d="$1"
  [ -b "$d" ] || return 1
  sig="$($BB dd if="$d" bs=1 skip=512 count=8 2>/dev/null || true)"
  [ "$sig" = "EFI PART" ] || return 1
  sz="$($BB cat "/sys/class/block/${d##*/}/size" 2>/dev/null || echo 0)"
  case "$sz" in
    ''|*[!0-9]*) return 1 ;;
  esac
  [ "$sz" -gt 1048576 ] || return 1
  return 0
}

find_userdata_dev() {
  for p in \
    /dev/block/bootdevice/by-name/userdata \
    /dev/block/platform/*/by-name/USERDATA \
    /dev/block/platform/*/by-name/userdata \
    /dev/block/by-name/USERDATA \
    /dev/block/by-name/userdata; do
    [ -e "$p" ] || continue
    if [ -L "$p" ]; then
      d="$($BB readlink -f "$p" 2>/dev/null || true)"
    else
      d="$p"
    fi
    [ -n "${d:-}" ] || continue
    is_container_dev "$d" && {
      echo "$d"
      return 0
    }
  done

  best=""
  best_sz=0
  for d in /dev/mmcblk0p* /dev/block/mmcblk0p*; do
    is_container_dev "$d" || continue
    sz="$($BB cat "/sys/class/block/${d##*/}/size" 2>/dev/null || echo 0)"
    case "$sz" in
      ''|*[!0-9]*) continue ;;
    esac
    if [ "$sz" -gt "$best_sz" ]; then
      best="$d"
      best_sz="$sz"
    fi
  done
  [ -n "$best" ] && echo "$best"
}

find_free_loop() {
  skip="${1:-}"
  l="$($BB losetup -f 2>/dev/null || true)"
  if [ -n "$l" ] && [ "$l" != "$skip" ] && [ -b "$l" ]; then
    echo "$l"
    return 0
  fi
  for l in /dev/loop0 /dev/loop1 /dev/loop2 /dev/loop3 /dev/loop4 /dev/loop5 /dev/loop6 /dev/loop7; do
    [ -b "$l" ] || continue
    [ "$l" = "$skip" ] && continue
    if ! $BB losetup "$l" >/dev/null 2>&1; then
      echo "$l"
      return 0
    fi
  done
  return 1
}

mount_boot_from() {
  src="$1"
  if $BB mount -t ext2 -o ro "$src" "$BOOT_MNT" >>"$LOGF" 2>&1 ||
    $BB mount -t ext4 -o ro "$src" "$BOOT_MNT" >>"$LOGF" 2>&1; then
    return 0
  fi
  return 1
}

mount_root_from() {
  src="$1"
  if $BB mount -t ext4 -o rw "$src" "$ROOT_MNT" >>"$LOGF" 2>&1 ||
    $BB mount -t ext4 -o ro "$src" "$ROOT_MNT" >>"$LOGF" 2>&1 ||
    $BB mount -t ext4 -o ro,noload "$src" "$ROOT_MNT" >>"$LOGF" 2>&1 ||
    $BB mount -t ext2 -o ro "$src" "$ROOT_MNT" >>"$LOGF" 2>&1; then
    return 0
  fi
  return 1
}

find_fdisk() {
  for p in /sbin/fdisk /usr/sbin/fdisk /usr/bin/fdisk /bin/fdisk; do
    [ -x "$p" ] && {
      echo "$p"
      return 0
    }
  done
  return 1
}

main() {
  mkdir -p /tmp "$BOOT_MNT" "$ROOT_MNT"
  : > "$LOGF"
  log "mount-peacock: probing container..."

  dev="$(find_userdata_dev || true)"
  if [ -z "$dev" ]; then
    log "mount-peacock: no valid userdata container found"
    exit 1
  fi

  boot_start=""
  root_start=""
  fdisk_cmd="$(find_fdisk || true)"
  if [ -n "$fdisk_cmd" ]; then
    l1="$(LD_LIBRARY_PATH=/sbin:/lib:/usr/lib "$fdisk_cmd" -l "$dev" 2>/dev/null | $BB awk -v d="$dev" '$1 ~ ("^" d "p1$") {print $2; exit}' || true)"
    l2="$(LD_LIBRARY_PATH=/sbin:/lib:/usr/lib "$fdisk_cmd" -l "$dev" 2>/dev/null | $BB awk -v d="$dev" '$1 ~ ("^" d "p2$") {print $2; exit}' || true)"
    case "$l1" in
      ''|*[!0-9]*) ;;
      *) boot_start="$l1" ;;
    esac
    case "$l2" in
      ''|*[!0-9]*) ;;
      *) root_start="$l2" ;;
    esac
  fi

  boot_off=""
  root_off=""
  [ -n "$boot_start" ] && boot_off=$((boot_start * 512))
  [ -n "$root_start" ] && root_off=$((root_start * 512))

  log "mount-peacock: device=$dev p1_start=${boot_start:-unknown} p2_start=${root_start:-unknown}"
  printf 'device=%s boot_start=%s root_start=%s\n' "$dev" "${boot_start:-unknown}" "${root_start:-unknown}" >> "$LOGF"

  $BB umount "$BOOT_MNT" 2>/dev/null || true
  $BB umount "$ROOT_MNT" 2>/dev/null || true

  boot_ok=0
  root_ok=0
  boot_src=""
  root_src=""
  main_loop=""
  boot_loop=""
  root_loop=""

  # Preferred: use loop partition mappings (avoids mount loop+offset parser quirks).
  if $BB --list 2>/dev/null | $BB grep -qx losetup; then
    main_loop="$(find_free_loop || true)"
    if [ -n "$main_loop" ] && [ -b "$main_loop" ]; then
      $BB losetup -d "$main_loop" >/dev/null 2>&1 || true
      if $BB losetup -P "$main_loop" "$dev" >>"$LOGF" 2>&1; then
        i=0
        while [ "$i" -lt 4 ]; do
          p1="/dev/${main_loop##*/}p1"
          p2="/dev/${main_loop##*/}p2"
          [ -b "$p1" ] && boot_src="$p1"
          [ -b "$p2" ] && root_src="$p2"
          [ -n "$boot_src" ] && [ -n "$root_src" ] && break
          $BB mdev -s >/dev/null 2>&1 || true
          i=$((i + 1))
          $BB sleep 1
        done
        [ -n "$boot_src" ] && mount_boot_from "$boot_src" && boot_ok=1 || true
        [ -n "$root_src" ] && mount_root_from "$root_src" && root_ok=1 || true
      fi
    fi
  fi

  # Fallback: explicit offset loops (only when GPT offsets were discovered).
  if [ "$root_ok" -ne 1 ] && [ -n "$root_off" ] && $BB --list 2>/dev/null | $BB grep -qx losetup; then
    [ -n "$main_loop" ] && $BB losetup -d "$main_loop" >/dev/null 2>&1 || true
    main_loop=""

    root_loop="$(find_free_loop || true)"
    if [ -n "$root_loop" ] && [ -b "$root_loop" ]; then
      $BB losetup -d "$root_loop" >/dev/null 2>&1 || true
      if $BB losetup -o "$root_off" "$root_loop" "$dev" >>"$LOGF" 2>&1; then
        if mount_root_from "$root_loop"; then
          root_ok=1
          root_src="$root_loop"
        else
          $BB losetup -d "$root_loop" >/dev/null 2>&1 || true
          root_loop=""
        fi
      fi
    fi

    if [ "$boot_ok" -ne 1 ] && [ -n "$boot_off" ]; then
      boot_loop="$(find_free_loop "$root_loop" || true)"
      if [ -n "$boot_loop" ] && [ -b "$boot_loop" ]; then
        $BB losetup -d "$boot_loop" >/dev/null 2>&1 || true
        if $BB losetup -o "$boot_off" "$boot_loop" "$dev" >>"$LOGF" 2>&1; then
          if mount_boot_from "$boot_loop"; then
            boot_ok=1
            boot_src="$boot_loop"
          else
            $BB losetup -d "$boot_loop" >/dev/null 2>&1 || true
            boot_loop=""
          fi
        fi
      fi
    fi
  fi

  # Last fallback: mount with loop+offset directly (only with discovered offsets).
  if [ "$boot_ok" -ne 1 ] && [ -n "$boot_off" ]; then
    if $BB mount -t ext2 -o ro,loop,offset="$boot_off" "$dev" "$BOOT_MNT" >>"$LOGF" 2>&1 ||
      $BB mount -t ext4 -o ro,loop,offset="$boot_off" "$dev" "$BOOT_MNT" >>"$LOGF" 2>&1; then
      boot_ok=1
      boot_src="$($BB awk -v m="$BOOT_MNT" '$2==m{print $1; exit}' /proc/mounts 2>/dev/null || true)"
    fi
  fi
  if [ "$root_ok" -ne 1 ] && [ -n "$root_off" ]; then
    if $BB mount -t ext4 -o rw,loop,offset="$root_off" "$dev" "$ROOT_MNT" >>"$LOGF" 2>&1 ||
      $BB mount -t ext4 -o ro,loop,offset="$root_off" "$dev" "$ROOT_MNT" >>"$LOGF" 2>&1 ||
      $BB mount -t ext4 -o ro,noload,loop,offset="$root_off" "$dev" "$ROOT_MNT" >>"$LOGF" 2>&1 ||
      $BB mount -t ext2 -o ro,loop,offset="$root_off" "$dev" "$ROOT_MNT" >>"$LOGF" 2>&1; then
      root_ok=1
      root_src="$($BB awk -v m="$ROOT_MNT" '$2==m{print $1; exit}' /proc/mounts 2>/dev/null || true)"
    fi
  fi

  if [ "$root_ok" -ne 1 ]; then
    log "mount-peacock: root mount failed (see $LOGF)"
    tail -n 20 "$LOGF" 2>/dev/null || true
    exit 1
  fi

  boot_src="$($BB awk -v m="$BOOT_MNT" '$2==m{print $1; exit}' /proc/mounts 2>/dev/null || true)"
  root_src="$($BB awk -v m="$ROOT_MNT" '$2==m{print $1; exit}' /proc/mounts 2>/dev/null || true)"
  [ -n "$boot_src" ] && ln -snf "$boot_src" "${dev}s0" 2>/dev/null || true
  [ -n "$root_src" ] && ln -snf "$root_src" "${dev}s1" 2>/dev/null || true

  if [ "$boot_ok" -eq 1 ]; then
    log "mount-peacock: mounted $BOOT_MNT and $ROOT_MNT"
  else
    log "mount-peacock: mounted $ROOT_MNT (boot mount skipped/failed)"
  fi
  $BB mount | $BB grep -E 'peacock_(boot|root)' || true
}

main "$@"
