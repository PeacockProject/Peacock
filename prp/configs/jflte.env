# PRP device config: Samsung Galaxy S4 (jflte / MSM8960)

TARGET_NAME="jflte"
BOARD_NAME="jflte"

# Android boot image params (from current peacock jflte profile)
CMDLINE="androidboot.hardware=qcom user_debug=31 zcache msm_rtb.filter=0x3F ehci-hcd.park=3 buildvariant=userdebug earlyprintk console=tty0,115200 console=tty1,115200 loglevel=7 fbcon=map:0"
BASE="0x80200000"
KERNEL_OFFSET="0x00008000"
RAMDISK_OFFSET="0x02000000"
SECOND_OFFSET="0x00f00000"
TAGS_OFFSET="0x00000100"
PAGESIZE="2048"
HEADER_VERSION="0"
APPEND_SEANDROIDENFORCE="1"

# Optional explicit paths. Use the Peacock/jflte kernel (boots on this device).
KERNEL_IMAGE="/home/tiel/Documents/bro/shen/prp/out/jflte/kernel-from-peacock.img"
DTB_IMAGE=""

# Keep empty for a unique PRP ramdisk. Set only for temporary fallback.
RAMDISK_PREBUILT=""

# Custom initramfs rootfs source, used by `make initramfs`.
INITRAMFS_ROOTFS="initramfs/rootfs"

# Runtime asset sync inputs.
ROOTFS_IMAGE="$HOME/.local/var/peacock/samsung-jflte.img"
ROOTFS_OFFSET_SECTORS="1050624"
ROOTFS_SIZE_SECTORS="6811648"
BUSYBOX_STATIC="$HOME/.local/var/peacock/busybox-cache/busybox-1.36.1-1-armv7h.pkg.tar.gz/busybox"
KERNEL_CONFIG="$HOME/.local/var/peacock/build-chroot/x86_64/build/linux-samsung-jflte-3.4.113.8-armv7/.config"

# Device flashing settings
ADB_PREFIX="sudo adb"
RECOVERY_BLOCK="/dev/block/mmcblk0p21"

# PRP GUI power-key mapping hints (device profile specific).
GUI_POWER_HINT="gpio-keys sec_key pwrkey pm8 qpnp_pon"
GUI_POWER_CODE="116"

# jflte panel keepalive helper.
USE_FB_REFRESHER="1"
