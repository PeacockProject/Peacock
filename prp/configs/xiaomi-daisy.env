# PRP device config: Xiaomi Mi A2 Lite (daisy / MSM8953)

TARGET_NAME="xiaomi-daisy"
# Keep boot image board field empty to match working Peacock daisy boot.img.
BOARD_NAME=""
TARGET_ARCH="aarch64"

# Android boot image params (from Peacock daisy profile)
CMDLINE="quiet loglevel=0 printk.devkmsg=on panic=3 ramoops.mem_address=0x9ff00000 ramoops.mem_size=0x100000 ramoops.console_size=0x80000 ramoops.pmsg_size=0x80000"
BASE="0x80000000"
KERNEL_OFFSET="0x00008000"
RAMDISK_OFFSET="0x01000000"
SECOND_OFFSET="0x00f00000"
TAGS_OFFSET="0x00000100"
PAGESIZE="2048"
HEADER_VERSION="0"
APPEND_SEANDROIDENFORCE="0"

# Leave empty to auto-resolve from local Peacock kernel cache/build outputs.
KERNEL_IMAGE=""
# Use PRP-focused kernel package for recovery bring-up.
KERNEL_PACKAGE="linux-xiaomi-daisy-prp"
DTB_IMAGE=""

# Keep empty for a unique PRP ramdisk.
RAMDISK_PREBUILT=""
RAMDISK_FORMAT="gzip"

INITRAMFS_ROOTFS="initramfs/rootfs"

# Runtime asset sync inputs.
ROOTFS_IMAGE="$HOME/.local/var/peacock/xiaomi-daisy.img"
ROOTFS_OFFSET_SECTORS="1050624"
ROOTFS_SIZE_SECTORS="9433088"
BUSYBOX_STATIC="$HOME/.local/var/peacock/busybox-cache/busybox-1.36.1-1-aarch64.pkg.tar.gz/busybox"
KERNEL_CONFIG="$HOME/.local/var/peacock/build-chroot/aarch64/build/linux-xiaomi-daisy-prp-6.16.3-r0-aarch64/.config"

# Daisy is flashed through fastboot boot partitions (A/B).
FLASH_METHOD="fastboot-bootimg"
FASTBOOT_PREFIX="fastboot"
# Generic A/B + lk2nd split-boot layout:
# - flash PRP boot payload via logical "boot" (lk2nd keeps its own 512KiB slice)
# - active slot selects whether this resolves to boot_a or boot_b.
FASTBOOT_AB_LK2ND_SPLIT_BOOT="1"
FASTBOOT_BOOT_PARTITION="boot"
FASTBOOT_LK2ND_PARTITION="lk2nd"
FASTBOOT_SET_ACTIVE="a"

# PRP initramfs can boot without copied TWRP adbd blobs.
REQUIRE_TWRP_SBIN="0"
USB_SERIAL="PRP-DAISY"
# Mainline daisy exposes UDC as /sys/class/udc/7000000.usb; prefer the
# platform android_usb node under that controller when present.
USB_GADGET_PATH="${USB_GADGET_PATH:-/sys/devices/platform/soc@0/7000000.usb/android0}"
USB_UDC_NAME="${USB_UDC_NAME:-7000000.usb}"
# PRP GUI power-key mapping hints (device profile specific).
GUI_POWER_HINT="qpnp_pon pwrkey pm8 gpio-keys"
# Daisy PRP kernel exposes pm8941_pwrkey (KEY_POWER=116).
GUI_POWER_CODE="116"
DO_MOUNT_SUBPARTS="0"
SUBPARTS_ASYNC="1"
SUBPARTS_DELAY_SECS="10"
MOUNT_PRP_ROOTFS="1"
# PRP rootfs is flashed into slot B boot partition for daisy.
# Use an explicit hint to avoid intermittent scan misses/races.
ROOTFS_DEV_HINT="/dev/block/bootdevice/by-name/boot_b /dev/mmcblk0p52"
# Peacock userdata image container on daisy.
USERDATA_DEV_HINT="/dev/block/bootdevice/by-name/userdata /dev/mmcblk0p60 /dev/block/mmcblk0p60"
# Re-enable framebuffer I/O for display validation.
ENABLE_FB_IO="1"
USE_FB_REFRESHER="0"
# Daisy now boots with display/TTY; keep splash/UI path enabled by default.
# Override with DEBUG_BOOT=1 when you explicitly want headless debug boot.
DEBUG_BOOT="${DEBUG_BOOT:-0}"
# Keep splash visible on daisy: do not mirror logs to tty/console and do not
# auto-enter local tty shells (SSH/raw shell paths remain available).
START_TTY_SHELLS="${START_TTY_SHELLS:-0}"
TEXT_CONSOLE_LOG="${TEXT_CONSOLE_LOG:-0}"
SMOKE_ONLY="0"

# Keep PRP rootfs mount-compatible across recovery kernels/userspace.
# Modern ext4 defaults (metadata_csum/64bit/orphan_file) intermittently fail
# with EINVAL in our current boot chain.
OVERLAY_EXT4_OPTS="-O ^metadata_csum,^metadata_csum_seed,^64bit,^orphan_file -E lazy_itable_init=0,lazy_journal_init=0"

# Prefer distro-provided dropbear binaries via sync-assets/runtime copy path.
# If unavailable, overlay build falls back to locally-built dropbear.
DROPBEAR_VER="2022.83"
